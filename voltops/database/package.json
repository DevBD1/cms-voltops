{
  "name": "@voltops/database",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm db:up",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "start": "pnpm db:up",
    "build": "echo \"Database image is managed by Docker Compose\"",
    "lint": "docker compose config -q"
  }
}
