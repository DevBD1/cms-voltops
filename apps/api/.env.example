PORT=3000

# Supabase Postgres connection string for the Express API.
# Copy this from: Supabase Dashboard → Connect → Direct connection tab.
# URL-encode any special characters in the password (? → %3F, @ → %40, % → %25, # → %23)
#
# Direct connection (port 5432) — works for long-running Node processes:
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.yplkmowedhdcclxdgtst.supabase.co:5432/postgres?sslmode=require
#
# Transaction pooler (port 6543) — use for serverless / edge functions:
# DATABASE_URL=postgresql://postgres.yplkmowedhdcclxdgtst:[YOUR-DB-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase Auth project values.
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://yplkmowedhdcclxdgtst.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_NzbjbbxVud_ZZmHcpP0XBw_Pw-vgUIc

# Set to true to enable verbose request / auth logging in dev
API_DEBUG=true
